{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DEK-DEBIAN/FARfetched-data/schemas/aircraft_model.schema.json",
  "title": "Aircraft model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manufacturer",
    "model_designation",
    "common_name",
    "categories",
    "notes",
    "tcb"
  ],
  "properties": {
    "manufacturer": { "type": "string", "minLength": 1 },
    "model_designation": { "type": "string", "minLength": 1 },
    "common_name": { "type": ["string", "null"] },
    "categories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "notes": { "type": ["string", "null"] },
    "tcb": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tcb" }
    }
  },
  "$defs": {
    "tcb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tcds", "notes", "certification_basis"],
      "properties": {
        "tcds": { "$ref": "#/$defs/tcds" },
        "notes": { "type": ["string", "null"] },
        "certification_basis": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/entry" }
        }
      }
    },
    "tcds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "tcds_number"],
      "properties": {
        "authority": { "enum": ["FAA"] },
        "tcds_number": { "type": "string", "minLength": 1 },
        "revision": { "type": ["string", "null"] },
        "revision_date": {
          "oneOf": [
            { "type": "string", "format": "date" },
            { "type": "null" }
          ]
        },
        "source_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_order",
        "entry_type",
        "raw_reference",
        "applicability_notes",
        "resolved_references"
      ],
      "properties": {
        "display_order": { "type": "integer", "minimum": 1 },
        "entry_type": {
          "enum": [
            "regulation",
            "special_condition",
            "elos",
            "exemption",
            "other"
          ]
        },
        "raw_reference": { "type": "string", "minLength": 1 },
        "applicability_notes": { "type": ["string", "null"] },
        "resolved_references": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["reference_kind"],
            "properties": {
              "reference_kind": { "enum": ["range", "single"] }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "reference_kind": { "const": "range" } },
                  "required": ["reference_kind"]
                },
                "then": { "$ref": "#/$defs/range_ref" }
              },
              {
                "if": {
                  "properties": { "reference_kind": { "const": "single" } },
                  "required": ["reference_kind"]
                },
                "then": { "$ref": "#/$defs/single_ref" }
              }
            ]
          }
        }
      }
    },
    "range_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_kind",
        "authority",
        "title_number",
        "part",
        "from_amendment_ordinal",
        "to_amendment_ordinal"
      ],
      "properties": {
        "reference_kind": { "const": "range" },
        "authority": { "enum": ["FAA"] },
        "title_number": { "type": "integer", "minimum": 1 },
        "part": { "type": "string", "minLength": 1 },
        "from_amendment_ordinal": { "type": "integer", "minimum": 0 },
        "to_amendment_ordinal": { "type": "integer", "minimum": 0 }
      }
    },
    "single_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_kind",
        "authority",
        "title_number",
        "part",
        "section",
        "amendment_designator"
      ],
      "properties": {
        "reference_kind": { "const": "single" },
        "authority": { "enum": ["FAA"] },
        "title_number": { "type": "integer", "minimum": 1 },
        "part": { "type": "string", "minLength": 1 },
        "section": { "type": "string", "minLength": 1 },
        "amendment_designator": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+-[0-9]+$"
        }
      }
    }
  }
}

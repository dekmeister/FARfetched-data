{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DEK-DEBIAN/FARfetched-data/schemas/regulation.schema.json",
  "title": "Regulation section",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "part",
    "section",
    "current_subpart",
    "canonical_title",
    "amendments"
  ],
  "properties": {
    "authority": { "enum": ["FAA", "CAA (FAA)", "CAB (FAA)", "EASA"] },
    "part": { "type": "string", "minLength": 1 },
    "section": { "type": "string", "minLength": 1 },
    "current_subpart": { "type": ["string", "null"] },
    "canonical_title": { "type": "string", "minLength": 1 },
    "subject_group": { "type": ["string", "null"] },
    "amendments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/amendment" }
    }
  },
  "$defs": {
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["designator", "title_at_amendment"],
      "oneOf": [
        { "required": ["text"] },
        { "required": ["same_as_designator"] }
      ],
      "properties": {
        "designator": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+-[0-9]+$"
        },
        "subpart_at_time": { "type": ["string", "null"] },
        "title_at_amendment": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "same_as_designator": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+-[0-9]+$"
        },
        "federal_register_cite": { "type": "string" },
        "source_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/amendment_action" }
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": { "enum": ["scraped", "ocr", "manual"] },
        "notes": { "type": "string" }
      }
    },
    "amendment_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "nprm",
            "final_rule",
            "direct_final_rule",
            "interim_final_rule",
            "easa_npa",
            "easa_opinion",
            "easa_decision",
            "jar_npa",
            "jar_change",
            "other"
          ]
        },
        "reference": { "type": ["string", "null"] },
        "issued_on": {
          "oneOf": [
            { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
            { "type": "null" }
          ]
        },
        "source_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}

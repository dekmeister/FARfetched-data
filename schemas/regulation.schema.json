{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DEK-DEBIAN/FARfetched-data/schemas/regulation.schema.json",
  "title": "Regulation section",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "title_number",
    "part",
    "subpart",
    "section",
    "canonical_title",
    "amendments"
  ],
  "properties": {
    "authority": { "enum": ["FAA"] },
    "title_number": { "type": "integer", "minimum": 1 },
    "part": { "type": "string", "minLength": 1 },
    "subpart": { "type": ["string", "null"] },
    "section": { "type": "string", "minLength": 1 },
    "canonical_title": { "type": "string", "minLength": 1 },
    "subject_group": { "type": ["string", "null"] },
    "amendments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/amendment" }
    }
  },
  "$defs": {
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designator",
        "ordinal",
        "effective_date",
        "title_at_amendment",
        "text",
        "source_url",
        "federal_register_cite"
      ],
      "properties": {
        "designator": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+-[0-9]+$"
        },
        "ordinal": { "type": "integer", "minimum": 0 },
        "effective_date": { "type": "string", "format": "date" },
        "title_at_amendment": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "format": "uri" },
        "federal_register_cite": { "type": "string", "minLength": 1 }
      }
    }
  }
}

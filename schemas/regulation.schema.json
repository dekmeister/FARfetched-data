{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DEK-DEBIAN/FARfetched-data/schemas/regulation.schema.json",
  "title": "Regulation section",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "part",
    "section",
    "current_subpart",
    "canonical_title",
    "amendments"
  ],
  "properties": {
    "authority": { "enum": ["FAA"] },
    "part": { "type": "string", "minLength": 1 },
    "section": { "type": "string", "minLength": 1 },
    "current_subpart": { "type": ["string", "null"] },
    "canonical_title": { "type": "string", "minLength": 1 },
    "subject_group": { "type": ["string", "null"] },
    "amendments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/amendment" }
    }
  },
  "$defs": {
    "amendment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["designator", "title_at_amendment", "text", "federal_register_cite"],
      "properties": {
        "designator": {
          "type": "string",
          "pattern": "^[A-Za-z0-9]+-[0-9]+$"
        },
        "subpart_at_time": { "type": ["string", "null"] },
        "title_at_amendment": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "federal_register_cite": { "type": "string", "minLength": 1 },
        "source_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
